cat > .gitignore << 'EOF'
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/
.next-dev/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
node_modules
.next
.env
.env.local
.env.production
.env.development
.DS_Store

# Next.js build output
.next/
out/
standalone/

# cache
.cache/
**/.next/cache/

# archives
*.tar.gz
*.zip

# env
.env
.env.local

# dependencies
node_modules/


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Large files and build artifacts
*.tar.gz
*.pack

# Cache directories
.cache/
deploy_bundle/
standalone/

# Webpack cache
**/.next/cache/
**/cache/webpack/
EOF